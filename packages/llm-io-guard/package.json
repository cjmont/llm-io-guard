{
  "name": "llm-io-guard",
  "version": "0.1.0",
  "description": "Offline, in-process input/output safety guard for LLM apps (PII vault, prompt-injection, secrets, malicious URLs, package hallucination). Rust core, Node (napi) + edge/browser (WASM). Defense-in-depth, not a guarantee.",
  "author": "carlosmontanor",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjmont/llm-io-guard.git"
  },
  "keywords": [
    "llm",
    "ai",
    "guardrails",
    "prompt-injection",
    "pii",
    "redaction",
    "gdpr",
    "secrets",
    "security",
    "wasm",
    "edge",
    "napi-rs"
  ],
  "type": "commonjs",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs"
    }
  },
  "files": ["dist", "binding.js", "binding.d.ts", "wasm"],
  "engines": { "node": ">=18" },
  "napi": {
    "binaryName": "llm-io-guard",
    "packageName": "llm-io-guard",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build:rust": "napi build --release --platform --js-package-name llm-io-guard --manifest-path ../../crates/llm-io-guard-napi/Cargo.toml --js binding.js --dts binding.d.ts --output-dir .",
    "build:rust:debug": "napi build --platform --js-package-name llm-io-guard --manifest-path ../../crates/llm-io-guard-napi/Cargo.toml --js binding.js --dts binding.d.ts --output-dir .",
    "build:wasm": "wasm-pack build ../../crates/llm-io-guard-wasm --release --target web --out-dir ../../packages/llm-io-guard/wasm --out-name llm-io-guard",
    "build:ts": "tsup",
    "build": "npm run build:rust && npm run build:wasm && npm run build:ts",
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "llm-io-guard-win32-x64-msvc": "0.1.0",
    "llm-io-guard-linux-x64-gnu": "0.1.0",
    "llm-io-guard-linux-arm64-gnu": "0.1.0",
    "llm-io-guard-darwin-x64": "0.1.0",
    "llm-io-guard-darwin-arm64": "0.1.0"
  }
}
